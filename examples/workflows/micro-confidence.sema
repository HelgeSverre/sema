;; ============================================================================
;; examples/workflows/micro-confidence.sema
;;
;; Demonstrates the `micro/confidence` package: tries a sequence of models,
;; accepting the first one that clears the confidence threshold. If all fail,
;; it falls back to the best candidate.
;; ============================================================================

(import "packages/micro")

(defworkflow confidence-example
  "Confidence escalation pattern"
  {:phases ["Run"]}
  (phase "Run")

  (def r
    (micro/confidence
      {:name "support-answer"
       :models ["ollama/qwen3-coder" "mistral/eu-small" "claude-sonnet-4-6"]
       :threshold 0.82
       :schema {:answer :string :confidence :number}}
      "Answer this support question using the docs."))

  {:status :success :result r})

;; ============================================================================
;; EXPECTED EVENTS (JSONL Journal)
;; ============================================================================
;; The `micro/confidence` macro emits typed events into the workflow journal
;; using the `workflow/tool-call` hook as a workaround.
;;
;; 1. Recipe Started:
;; {"event": "agent.tool_call", "agent_name": "...", "tool_name": "micro.recipe.started", "args_json": {"recipe": "confidence", "name": "support-answer"}}
;;
;; 2. Candidate Completed (for each model):
;; {"event": "agent.tool_call", "agent_name": "...", "tool_name": "micro.candidate.completed", "args_json": {"model": "ollama/qwen3-coder", "confidence": 0.5}}
;;
;; 3. Escalated (if confidence < threshold or schema invalid):
;; {"event": "agent.tool_call", "agent_name": "...", "tool_name": "micro.escalated", "args_json": {"from": "ollama/qwen3-coder", "to": "mistral/eu-small", "reason": "confidence_below_threshold"}}
;;
;; 4. Recipe Ended (accepted or fallback):
;; {"event": "agent.tool_call", "agent_name": "...", "tool_name": "micro.recipe.ended", "args_json": {"decision": "accepted", "model": "mistral/eu-small"}}
