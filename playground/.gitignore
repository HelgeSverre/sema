# wasm-pack builds the pkg directory
# We check it in so Vercel can deploy it as static files
# But ignore the .gitignore that wasm-pack creates inside pkg/
pkg/.gitignore
dist/
node_modules/
test-results/
playwright-report/
.vercel
# Local-dev Chrome DevTools workspace descriptor (embeds an absolute path;
# generated by scripts/gen-devtools-json.mjs via `make playground-dev`).
.well-known/
