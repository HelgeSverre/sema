{
  "name": "@sema/ui",
  "description": "Web Components for the Sema design system. Lit-based, framework-agnostic, consumes DESIGN.md tokens via CSS custom properties.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./standalone": {
      "import": "./dist/sema-ui.js"
    },
    "./tokens.css": "./src/styles/tokens.css",
    "./syntax.css": "./src/styles/syntax.css"
  },
  "files": [
    "src",
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "analyze": "cem analyze",
    "export:typer": "node scripts/export-typer.mjs"
  },
  "dependencies": {
    "@lit/task": "^1.0.3",
    "@shikijs/langs": "^4.2.0",
    "@vitest/ui": "^4.1.8",
    "lit": "^3.3.3",
    "shiki": "^4.2.0"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/js": "^9.39.4",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-wc": "^3.1.0",
    "gifenc": "^1.0.3",
    "playwright": "^1.60.0",
    "sharp": "^0.35.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.8"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "esbuild@0.25.12": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  },
  "customElements": "custom-elements.json"
}
